# Groq LLM (Phase 2+) — get your key at https://console.groq.com/
GROQ_API_KEY=

# Default model for lib/llm.ts
# Quality: llama-3.3-70b-versatile | Speed: llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — Groq API endpoint (default shown)
GROQ_BASE_URL=https://api.groq.com

# Upload limit for resume files (MB)
MAX_UPLOAD_MB=5
